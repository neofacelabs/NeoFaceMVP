# ── Redis ─────────────────────────────────────────────────────────────────────
# LOCAL (Docker Compose): redis://localhost:6379/0
# PRODUCTION: redis://<host>:<port>/0
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Face Recognition ──────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.65
LIVENESS_THRESHOLD=60.0
MAX_ENROLLMENT_IMAGES=5
MIN_ENROLLMENT_IMAGES=1
FACE_DETECTION_MODEL=buffalo_l
EMBEDDING_DIMENSION=512

# ── Storage Backend ───────────────────────────────────────────────────────────
# Options: local | s3 | supabase
# Use "local" for development with Docker Compose.
STORAGE_BACKEND=supabase

# Local filesystem (used when STORAGE_BACKEND=local)
LOCAL_STORAGE_PATH=./storage/faces

# AWS S3 (used when STORAGE_BACKEND=s3)
AWS_S3_BUCKET=neoface-faces
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT_URL=

# ── Anti-Spoofing / Liveness Pipeline ────────────────────────────────────────
# Path to MiniFASNet ONNX model. Run: python scripts/download_models.py --all
ANTI_SPOOF_MODEL_PATH=./models/anti_spoof.onnx
# Probability threshold for real/spoof classification (0.0–1.0)
ANTI_SPOOF_THRESHOLD=0.70
# Set to false to disable anti-spoof (e.g. development without model file)
ANTI_SPOOF_ENABLED=true
# Use full 6-stage pipeline (true) or legacy single-stage MediaPipe (false)
USE_LIVENESS_PIPELINE=true

# ── Trust Engine v2 — Model Paths ─────────────────────────────────────────────
# Download all models with: python scripts/download_models.py --all
# Check model status with:  python scripts/download_models.py --status
#
# Passive Liveness: MiniFASNetV1 + V2 ensemble
MINIFASNET_V1_PATH=./models/MiniFASNetV1.onnx
MINIFASNET_V2_PATH=./models/MiniFASNetV2.onnx
#
# Emotion Recognition: FER+ 8-class ONNX
EMOTION_MODEL_PATH=./models/emotion_mobilenetv3.onnx
#
# Depth Estimation: MiDaS Small (fast, ~63 MB) + DPT Hybrid (high-quality, ~508 MB)
MIDAS_SMALL_PATH=./models/midas_small.onnx
DPT_HYBRID_PATH=./models/dpt_hybrid.onnx
#
# Deepfake Detection: ViT primary + secondary ensemble
EFFICIENTNET_DEEPFAKE_PATH=./models/efficientnet_b4_deepfake.onnx
XCEPTIONNET_DEEPFAKE_PATH=./models/xceptionnet_deepfake.onnx

# ── Model Verification ────────────────────────────────────────────────────────
# false (dev):  logs warnings for missing models, uses heuristic fallbacks.
# true  (prod): startup fails if any required model file is absent.
STRICT_MODEL_VERIFICATION=false

# ── Model Preloading ──────────────────────────────────────────────────────────
# false (default): models lazy-load on-demand when requested to avoid OOM.
# true  (prod):    models warm up at startup (requires ≥4GB RAM).
PRELOAD_MODELS=false

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_VERIFICATION=10/minute
RATE_LIMIT_ENROLLMENT=5/minute

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
# Default admin credentials (CHANGE THESE IN PRODUCTION)
ADMIN_EMAIL=admin@neoface.io
ADMIN_PASSWORD=<change-this-strong-password>
ADMIN_NAME=NeoFace Admin

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/neoface.log
