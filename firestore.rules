rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // By default, secure all collections. Only allow backend service accounts (which bypass rules)
    // or specifically authorized client operations to read/write.
    match /{document=**} {
      allow read, write: if false;
    }

    // If client terminals need to listen to real-time session verification status
    match /auth_sessions/{sessionId} {
      allow read: if request.auth != null;
    }

    // Allow users to view and manage their own profile details
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.uid == resource.data.uid);
      allow create: if request.auth != null && (request.auth.uid == userId || request.auth.uid == request.resource.data.uid);
      allow update: if request.auth != null 
                    && (request.auth.uid == userId || request.auth.uid == resource.data.uid)
                    && (!('neoId' in resource.data) || request.resource.data.neoId == resource.data.neoId)
                    && (!('qrCode' in resource.data) || request.resource.data.qrCode == resource.data.qrCode)
                    && (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt);
      allow delete: if false; // NeoID profiles can never be deleted
    }
  }
}

