# ── Database (Supabase PostgreSQL via asyncpg) ────────────────────────────────
# Replace [YOUR-PASSWORD] with your Supabase project database password.
# Found in: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql+asyncpg://postgres.pblpwhahvwwemxhvfppd:NeoFace%402026@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Supabase Project Credentials ──────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://pblpwhahvwwemxhvfppd.supabase.co
SUPABASE_PROJECT_REF=pblpwhahvwwemxhvfppd

# Anon (public) key — safe for client-side use, RLS enforced
SUPABASE_ANON_KEY=sb_publishable_g3KDGWtSCwq88ORJHQMAAA_4gR1SFdU

# Service role key — FULL DB ACCESS, server-side only, KEEP SECRET
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBibHB3aGFodnd3ZW14aHZmcHBkIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MjM2NDY0OSwiZXhwIjoyMDk3OTQwNjQ5fQ.orE66iXubOO3-6eNNSZTxWUmL2wkAVFpb-apOj-JIvs

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Face Recognition ──────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.65
LIVENESS_THRESHOLD=60.0
MAX_ENROLLMENT_IMAGES=5
MIN_ENROLLMENT_IMAGES=1
FACE_DETECTION_MODEL=buffalo_l
EMBEDDING_DIMENSION=512

# ── Storage Backend ───────────────────────────────────────────────────────────
# Options: local | s3 | supabase
# Set to "supabase" to use Supabase Storage buckets.
STORAGE_BACKEND=s3

# Local filesystem (used when STORAGE_BACKEND=local)
LOCAL_STORAGE_PATH=./storage/faces

# AWS S3 (used when STORAGE_BACKEND=s3)
AWS_S3_BUCKET=neoface-biometrics
AWS_S3_REGION=auto
AWS_ACCESS_KEY_ID=db78e814ea19417dc4bf06c435f8a9af
AWS_SECRET_ACCESS_KEY=e9d2bd1c6c2f06f12e4ea3c4287e599c5118a5352d10ab674ea5e3926ac88b7b
AWS_S3_ENDPOINT_URL=https://0054861b0f8cf58efed44d5e4a656cc4.r2.cloudflarestorage.com

# Supabase Storage bucket names (used when STORAGE_BACKEND=supabase)
# Create these buckets in: Supabase Dashboard → Storage
SUPABASE_BUCKET_FACE_IMAGES=face-images
SUPABASE_BUCKET_VERIFICATION_IMAGES=verification-images
SUPABASE_BUCKET_LOGS=logs

# ── Anti-Spoofing / Liveness Pipeline ────────────────────────────────────
# Path to MiniFASNet ONNX model. See models/README.md for download instructions.
ANTI_SPOOF_MODEL_PATH=./models/anti_spoof.onnx
# Probability threshold for real/spoof classification (0.0–1.0)
ANTI_SPOOF_THRESHOLD=0.70
# Set to false to disable anti-spoof (e.g. development without model file)
ANTI_SPOOF_ENABLED=false
# Use full 6-stage pipeline (true) or legacy single-stage MediaPipe (false)
USE_LIVENESS_PIPELINE=true

# ── Trust Engine v2 — Model Paths ─────────────────────────────────────────────
# Run: python scripts/download_models.py --all   to fetch downloadable models.
# Run: python scripts/download_models.py --status  to see what's missing.
#
# Passive Liveness: MiniFASNetV1 + V2 ensemble
MINIFASNET_V1_PATH=./models/MiniFASNetV1.onnx
MINIFASNET_V2_PATH=./models/MiniFASNetV2.onnx
#
# Emotion Recognition: MobileNetV3 (FER2013 fine-tune)
EMOTION_MODEL_PATH=./models/emotion_mobilenetv3.onnx
#
# Depth Estimation: MiDaS Small (fast, ~50 MB) + DPT Hybrid (optional, ~700 MB)
MIDAS_SMALL_PATH=./models/midas_small.onnx
DPT_HYBRID_PATH=./models/dpt_hybrid.onnx
#
# Deepfake Detection: EfficientNet-B4 + XceptionNet (FaceForensics++ fine-tune)
EFFICIENTNET_DEEPFAKE_PATH=./models/efficientnet_b4_deepfake.onnx
XCEPTIONNET_DEEPFAKE_PATH=./models/xceptionnet_deepfake.onnx

# ── Model Verification ────────────────────────────────────────────────────────
# false (dev): logs warnings for missing models but continues with heuristics.
# true  (prod): startup fails if any required model file is absent.
STRICT_MODEL_VERIFICATION=false

# ── Model Preloading ──────────────────────────────────────────────────────────
# false (default): models lazy-load on-demand when requested to avoid OOM.
# true  (prod):    models warm up at startup (requires ≥4GB RAM).
PRELOAD_MODELS=false

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_VERIFICATION=10/minute
RATE_LIMIT_ENROLLMENT=5/minute

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@neoface.io
ADMIN_PASSWORD=AdminPass123!
ADMIN_NAME=NeoFace Admin

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/neoface.log
